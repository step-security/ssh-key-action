{
  "name": "install-ssh-key",
  "version": "2.8.0",
  "private": true,
  "description": "Install SSH key in .ssh",
  "main": "./dist/main.js",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "build": "esbuild ./src/main.ts ./src/post.ts --bundle --platform=node --minify --sourcemap --outdir=./dist",
    "check-updates": "ncu",
    "lint": "run-p lint:*",
    "lint:es": "eslint ./src --ext .ts",
    "lint:ts": "tsc --noEmit ./src/main.ts ./src/post.ts",
    "lint:md": "markdownlint . --ignore node_modules --ignore examples",
    "lint:yaml": "yamllint **/{,.}*.{yml,yaml} --ignore=node_modules/**",
    "verify": "run-p lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/ssh-key-action.git"
  },
  "keywords": [
    "actions",
    "github actions",
    "rsync",
    "ssh",
    "ssh key"
  ],
  "license": "MIT",
  "devDependencies": {
    "@actions/core": "3.0.0",
    "@stylistic/eslint-plugin": "5.7.1",
    "@types/node": "25.2.0",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "axios": "^1.7.4",
    "esbuild": "0.27.2",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.5.1",
    "markdownlint-cli": "0.47.0",
    "npm-check-updates": "19.3.2",
    "npm-run-all": "4.1.5",
    "typescript": "5.9.3",
    "yaml-lint": "1.7.0"
  },
  "volta": {
    "node": "24.13.0",
    "npm": "11.6.2"
  }
}
